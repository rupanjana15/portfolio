---
import SectionHeading from "./SectionHeading.astro";
---

<section id="contact" class="section contact-section">
  <SectionHeading eyebrow="Get In Touch" title="Contact Me" />
  <div class="contact-layout">
    <div class="contact-copy">
      <p>I’m open to internships, entry-level roles, collaborations, and project conversations.</p>
      <div class="contact-actions">
        <a class="contact-link" href="mailto:rupp1510@gmail.com"><i class="fa-solid fa-envelope"></i> rupp1510@gmail.com</a>
        <a class="contact-link" href="https://www.linkedin.com/in/rupanjanac/" target="_blank" rel="noreferrer"><i class="fa-brands fa-linkedin"></i> LinkedIn</a>
        <button class="contact-link copy-email" type="button"><i class="fa-solid fa-copy"></i> Copy Email</button>
      </div>
    </div>
    <div class="contact-gallery" aria-label="Gallery">
      <img src="/assets/cat.jpeg" alt="" loading="lazy" />
      <img src="/assets/cat2.jpeg" alt="" loading="lazy" />
      <img src="/assets/cat3.jpeg" alt="" loading="lazy" />
    </div>
  </div>
</section>
